{
  "manifest_version": 3,
  "name": "MathCapy+",
  "version": "1.0",
  "description": "框選文字，轉換含數學公式為 LaTeX，複製至剪貼簿。",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "clipboardWrite"
  ],
  "host_permissions": ["<all_urls>"],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "MathCapy+",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "commands": {
    "capture_area": {
      "suggested_key": {
        "default": "Ctrl+C"
      },
      "description": "框選後截圖並轉為 LaTeX"
    }
  }
}
